# Copiá este archivo a .env y completá los valores.
#   cp .env.example .env
# El .env real NO se versiona (está en .gitignore).

# Client ID de tu app de Spotify → https://developer.spotify.com/dashboard
# Redirect URI que hay que registrar en la app: http://127.0.0.1:5173/callback
VITE_SPOTIFY_CLIENT_ID=

# API key de Anthropic → https://console.anthropic.com/settings/keys
# Vive SOLO en el backend; nunca se expone al navegador.
ANTHROPIC_API_KEY=
